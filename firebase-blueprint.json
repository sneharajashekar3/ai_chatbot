{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile document",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User's unique ID" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "URL to the user's profile photo" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of account creation" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Timestamp of last update" }
      },
      "required": ["uid", "email", "createdAt", "updatedAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat session",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique chat ID" },
        "title": { "type": "string", "description": "Chat title" },
        "model": { "type": "string", "description": "AI model used in the chat" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of chat creation" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Timestamp of last update" }
      },
      "required": ["id", "title", "model", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message within a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique message ID" },
        "role": { "type": "string", "enum": ["user", "model"], "description": "Role of the message sender" },
        "text": { "type": "string", "description": "Message content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of message creation" },
        "mediaUrl": { "type": "string", "description": "URL of the generated media." },
        "mediaType": { "type": "string", "enum": ["image", "video", "audio"], "description": "Type of the generated media." },
        "groundingUrls": { "type": "array", "items": { "type": "string" }, "description": "URLs for search/maps grounding." }
      },
      "required": ["id", "role", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    },
    "/users/{userId}/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Stores user's chat sessions"
    },
    "/users/{userId}/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores messages within a chat session"
    }
  }
}
